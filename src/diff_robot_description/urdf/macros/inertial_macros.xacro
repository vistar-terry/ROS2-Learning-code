<?xml version="1.0"?>
<!--
  macros/inertial_macros.xacro
  惯性参数计算宏

  功能：提供常用的惯性矩阵计算宏
  知识点：
  - 刚体惯性张量的计算方法
  - 常见几何体（长方体、圆柱体、球体）的惯性公式
  - Gazebo 中惯性参数的重要性

  惯性张量公式（参考坐标系在质心）：

  长方体 (长l, 宽w, 高h, 质量m)：
    Ixx = m/12 * (w² + h²)
    Iyy = m/12 * (l² + h²)
    Izz = m/12 * (l² + w²)

  圆柱体 (半径r, 高h, 质量m)：
    Ixx = Iyy = m/12 * (3r² + h²)
    Izz = m/2 * r²

  球体 (半径r, 质量m)：
    Ixx = Iyy = Izz = 2/5 * m * r²
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="inertial_macros">

  <!-- ============================================================
       宏：长方体惯性参数
       参数：
         x, y, z  - 长方体尺寸（米）
         mass     - 质量（千克）
       ============================================================ -->
  <xacro:macro name="box_inertial" params="x y z mass">
    <inertial>
      <mass value="${mass}" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <!-- 长方体惯性公式 -->
      <inertia ixx="${mass / 12.0 * (y*y + z*z)}"
               ixy="0" ixz="0"
               iyy="${mass / 12.0 * (x*x + z*z)}"
               iyz="0"
               izz="${mass / 12.0 * (x*x + y*y)}" />
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       宏：圆柱体惯性参数
       参数：
         radius   - 半径（米）
         length   - 长度/高度（米）
         mass     - 质量（千克）
       ============================================================ -->
  <xacro:macro name="cylinder_inertial" params="radius length mass">
    <inertial>
      <mass value="${mass}" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <!-- 圆柱体惯性公式 -->
      <inertia ixx="${mass / 12.0 * (3*radius*radius + length*length)}"
               ixy="0" ixz="0"
               iyy="${mass / 12.0 * (3*radius*radius + length*length)}"
               iyz="0"
               izz="${mass / 2.0 * radius*radius}" />
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       宏：球体惯性参数
       参数：
         radius   - 半径（米）
         mass     - 质量（千克）
       ============================================================ -->
  <xacro:macro name="sphere_inertial" params="radius mass">
    <inertial>
      <mass value="${mass}" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <!-- 球体惯性公式 -->
      <inertia ixx="${2.0/5.0 * mass * radius*radius}"
               ixy="0" ixz="0"
               iyy="${2.0/5.0 * mass * radius*radius}"
               iyz="0"
               izz="${2.0/5.0 * mass * radius*radius}" />
    </inertial>
  </xacro:macro>

</robot>
