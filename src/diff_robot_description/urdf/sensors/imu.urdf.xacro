<?xml version="1.0"?>
<!--
  sensors/imu.urdf.xacro
  IMU 惯性测量单元传感器 Xacro 宏

  功能：定义 IMU 的视觉、碰撞、惯性及 Gazebo 传感器插件

  知识点：
  - Gazebo IMU 传感器插件配置
  - IMU 数据：加速度(xyz) + 角速度(xyz) + 姿态(四元数)
  - 话题发布：sensor_msgs/Imu
  - IMU 噪声模型和偏差参数

  默认参数（模拟 BNO055 类 IMU）：
  - 更新频率：100Hz
  - 加速度噪声：0.01 m/s²
  - 角速度噪声：0.001 rad/s
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="imu_sensor">

  <xacro:include filename="$(find diff_robot_description)/urdf/macros/inertial_macros.xacro" />

  <!-- ============================================================
       IMU 传感器宏
       参数：
         parent        - 父坐标系名
         prefix        - 命名前缀
         xyz           - 安装位置
         rpy           - 安装姿态
         update_rate   - 数据发布频率（Hz）
       ============================================================ -->
  <xacro:macro name="imu_sensor" params="
    parent:=base_link
    prefix:=imu
    xyz:='0 0 0.10'
    rpy:='0 0 0'
    update_rate:=100">

    <!-- IMU link（小方块，模拟 IMU 芯片） -->
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <!-- IMU 芯片：1.5cm x 1.5cm x 0.3cm -->
          <box size="0.015 0.015 0.003" />
        </geometry>
        <material name="blue">
          <color rgba="0.0 0.0 0.8 1.0" />
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.015 0.015 0.003" />
        </geometry>
      </collision>

      <!-- 惯性参数：IMU芯片约0.005kg -->
      <xacro:box_inertial x="0.015" y="0.015" z="0.003" mass="0.005" />
    </link>

    <!-- IMU joint -->
    <joint name="${prefix}_joint" type="fixed">
      <parent link="${parent}" />
      <child link="${prefix}_link" />
      <origin xyz="${xyz}" rpy="${rpy}" />
    </joint>

    <!-- Gazebo IMU 传感器插件 -->
    <gazebo reference="${prefix}_link">
      <material>Gazebo/Grey</material>
      <gravity>true</gravity>

      <sensor name="${prefix}_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>${update_rate}</update_rate>
        <visualize>false</visualize>

        <imu>
          <!-- 角速度噪声模型 -->
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.001</stddev>     <!-- 0.001 rad/s 标准差 -->
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0001</bias_stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.001</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0001</bias_stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.001</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.0001</bias_stddev>
              </noise>
            </z>
          </angular_velocity>

          <!-- 线性加速度噪声模型 -->
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>      <!-- 0.01 m/s² 标准差 -->
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.001</bias_stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.001</bias_stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.01</stddev>
                <bias_mean>0.0</bias_mean>
                <bias_stddev>0.001</bias_stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>

        <!-- Gazebo ROS IMU 插件 -->
        <plugin name="${prefix}_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <namespace></namespace>
            <remapping>~/out:=imu/data</remapping>
          </ros>
          <initial_orientation_as_reference>false</initial_orientation_as_reference>
          <frame_name>${prefix}_link</frame_name>
        </plugin>
      </sensor>
    </gazebo>

  </xacro:macro>

</robot>
